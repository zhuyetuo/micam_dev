# Copy this file to .env and fill in the blanks:
#   cp .env.example .env

TZ=Asia/Shanghai

# ---------------------------------------------------------------------------
# Miloco (Xiaomi backend that authenticates with your Mi account)
# ---------------------------------------------------------------------------
MILOCO_PORT=8000
MILOCO_LOG_LEVEL=warning
# Only override if the "miloco" hostname doesn't resolve on your Docker setup
# (e.g. some rootless/podman configs). Leave commented out otherwise.
# MILOCO_HOST_IP=192.168.1.10

# ---------------------------------------------------------------------------
# Camera 1 (required)
# ---------------------------------------------------------------------------
# Miloco WebUI password, as an MD5 hash (lowercase). Pick any password, then:
#   ./scripts/gen_password.sh "your-chosen-password"
# Put the resulting hash here, and use the PLAIN password when you log into
# the Miloco WebUI for the first time.
MILOCO_PASSWORD=

# Camera device id (DID). Find it via the Miloco WebUI network log, see
# README.md "获取 CAMERA_ID".
CAMERA_ID=

# Where micam should publish this camera's stream inside go2rtc.
# Each camera needs a unique path.
RTSP_URL=rtsp://127.0.0.1:8554/cam0

# hevc (H.265, default) or h264, depending on what your camera model outputs.
VIDEO_CODEC=hevc

# Some dual-lens / PTZ cameras expose multiple channels; 0 is the main stream.
STREAM_CHANNEL=0

# ---------------------------------------------------------------------------
# Camera 2 (optional) - also set `micam2.scale: 1` in docker-compose.yml
# ---------------------------------------------------------------------------
CAMERA_2_ID=
CAMERA_2_RTSP_URL=rtsp://127.0.0.1:8554/cam1
